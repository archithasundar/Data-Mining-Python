from selenium import webdriver
import requests
import time

from selenium.webdriver.chrome.service import Service as ChromeService
from selenium.webdriver.chrome.options import Options
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC
from selenium.webdriver.common.by import By

from webdriver_manager.chrome import ChromeDriverManager
from openpyxl import Workbook


# Chrome Setup
options = Options()
options.add_argument("--ignore-certificate-errors")
options.add_argument("--test-type")
options.add_experimental_option("detach", True)

driver = webdriver.Chrome(
    service=ChromeService(ChromeDriverManager().install()),
    options=options
)


# Open Website
driver.get("Enter your URL")
driver.maximize_window()

wait = WebDriverWait(driver, 20)


# Excel Setup
excel_file_path = r"Enter Excel file path.xlsx"

workbook = Workbook()
workbook.save(excel_file_path)


page_number = 0
page_count = 0

xpath_index = 7

next_button_xpath = f"Enter your XPath[{xpath_index}]/a"


while page_count < 100:

    try:

        url = "Enter your URL"

        response = requests.get(url)

        if response.status_code == 200:

            data_boxes = wait.until(
                EC.presence_of_all_elements_located(
                    (By.CLASS_NAME, "card-view")
                )
            )


            sheet_name = f"Data_{page_number + 1}"
            sheet = workbook.create_sheet(title=sheet_name)

            extracted_data = []


            for box in data_boxes:

                title = (
                    box.find_element(By.CLASS_NAME, "title")
                    .find_element(By.TAG_NAME, "span")
                    .text.strip()
                )

                value = (
                    box.find_element(By.CLASS_NAME, "value")
                    .find_element(By.TAG_NAME, "span")
                    .text.strip()
                )

                extracted_data.append([title, value])


            for row in extracted_data:
                sheet.append(row)


            workbook.save(excel_file_path)

            print(
                f"Data extracted successfully from page {page_number + 1}"
            )


            driver.execute_script(
                "window.scrollTo(0, document.body.scrollHeight)"
            )


            button_xpath = f"Enter your XPath[{xpath_index}]/a"

            next_button = wait.until(
                EC.presence_of_element_located(
                    (By.XPATH, button_xpath)
                )
            )


            next_button.click()


            page_count += 1
            page_number += 1


            # Adjust according to website pagination structure
            if page_count == 1:
                xpath_index += 3

            elif page_count < 6:
                xpath_index += 1

            elif page_count > 44:
                xpath_index -= 1

            else:
                xpath_index = 14


            time.sleep(5)


    except Exception as error:

        print(
            f"Error during extraction: {error}"
        )


print("Scraping Completed")

driver.quit()
