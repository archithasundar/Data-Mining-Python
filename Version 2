# Version 2: Here you manually enter XPath of each page. Change conditions of the code according to your requirements.

from selenium import webdriver
import time

from selenium.webdriver.chrome.service import Service as ChromeService
from selenium.webdriver.chrome.options import Options
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC
from selenium.webdriver.common.by import By

from webdriver_manager.chrome import ChromeDriverManager
from openpyxl import Workbook


# Chrome Setup

options = Options()
options.add_argument("--ignore-certificate-errors")
options.add_argument("--test-type")
options.add_experimental_option("detach", True)


driver = webdriver.Chrome(
    service=ChromeService(ChromeDriverManager().install()),
    options=options
)


driver.get("Enter your URL")
driver.maximize_window()

wait = WebDriverWait(driver,20)



# Excel Setup

excel_file_path = r"Enter Excel file path.xlsx"

workbook = Workbook()

workbook.save(excel_file_path)



page_number = 0



while page_number < 100:


    try:


        data_boxes = wait.until(
            EC.presence_of_all_elements_located(
                (By.CLASS_NAME,"card-view")
            )
        )


        sheet_name = f"Data_{page_number + 1}"

        sheet = workbook.create_sheet(
            title=sheet_name
        )


        extracted_data = []


        for box in data_boxes:


            title = (
                box.find_element(By.CLASS_NAME,"title")
                .find_element(By.TAG_NAME,"span")
                .text.strip()
            )


            value = (
                box.find_element(By.CLASS_NAME,"value")
                .find_element(By.TAG_NAME,"span")
                .text.strip()
            )


            extracted_data.append(
                [title,value]
            )



        for row in extracted_data:

            sheet.append(row)



        workbook.save(excel_file_path)


        print(
            f"Page {page_number + 1} saved successfully"
        )



        driver.execute_script(
            "window.scrollTo(0,document.body.scrollHeight)"
        )


        next_xpath = input(
            f"Enter XPath for page {page_number + 2}: "
        )


        next_button = wait.until(
            EC.presence_of_element_located(
                (By.XPATH,next_xpath)
            )
        )


        next_button.click()


        time.sleep(5)


        page_number += 1



    except Exception as error:


        print(
            f"Error: {error}"
        )

        break



print("Scraping Completed")

driver.quit()
